---
import BlogLayout from '../layouts/BlogLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf()
).slice(0, 6);
---

<BlogLayout title="Accueil" description="Blog technique sur Java, le craft logiciel et les design patterns par Anis Ikram, Software Engineer.">
  <!-- Hero Section -->
  <section class="relative overflow-hidden bg-gradient-to-br from-base-100 via-base-100 to-base-200 py-16 sm:py-24">
    <!-- Decorative background elements -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
      <div class="absolute -top-24 -right-24 w-96 h-96 bg-primary/5 rounded-full blur-3xl"></div>
      <div class="absolute -bottom-24 -left-24 w-96 h-96 bg-secondary/5 rounded-full blur-3xl"></div>
    </div>

    <div class="container mx-auto px-6 relative">
      <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-16">
        <!-- Left: Text content -->
        <div class="flex-1 text-center lg:text-left animate-fade-in-up">
          <p class="text-sm font-semibold text-primary uppercase tracking-widest mb-4">Blog Technique</p>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight leading-tight mb-6">
            Salut, moi c'est <span class="gradient-text">Anis Ikram</span>
          </h1>
          <p class="text-lg sm:text-xl text-base-content/60 leading-relaxed max-w-xl mb-8">
            Software Engineer passionné par <strong class="text-base-content font-semibold">Java</strong>,
            le <strong class="text-base-content font-semibold">craft</strong> et les
            <strong class="text-base-content font-semibold">design patterns</strong>.
            Je partage ici mes découvertes et réflexions techniques.
          </p>
          <div class="flex flex-wrap justify-center lg:justify-start gap-4">
            <a href="/blog" class="btn btn-primary btn-md shadow-lg shadow-primary/20 hover:shadow-primary/40 transition-shadow">
              Voir les articles
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-1" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
              </svg>
            </a>
            <a href="/about" class="btn btn-ghost btn-md">
              En savoir plus sur moi
            </a>
          </div>
        </div>

        <!-- Right: Decorative code snippet -->
        <div class="flex-1 hidden lg:block animate-fade-in-up" style="animation-delay: 0.2s" aria-hidden="true">
          <div class="relative">
            <!-- Floating tech badges -->
            <div class="absolute -top-4 -left-4 badge badge-lg bg-primary/10 text-primary border-primary/20 font-mono text-xs animate-float" style="animation-delay: 0s">☕ Java</div>
            <div class="absolute -top-2 right-8 badge badge-lg bg-secondary/10 text-secondary border-secondary/20 font-mono text-xs animate-float" style="animation-delay: 0.5s">🧪 TDD</div>
            <div class="absolute -bottom-4 -left-2 badge badge-lg bg-secondary/10 text-secondary border-secondary/20 font-mono text-xs animate-float" style="animation-delay: 1s">✨ Clean Code</div>
            <div class="absolute -bottom-2 right-4 badge badge-lg bg-primary/10 text-primary border-primary/20 font-mono text-xs animate-float" style="animation-delay: 1.5s">🧩 DDD</div>

            <!-- Code window -->
            <div class="bg-base-200 rounded-xl border border-base-300 shadow-xl overflow-hidden">
              <!-- Window header -->
              <div class="flex items-center gap-2 px-4 py-3 bg-base-300/50 border-b border-base-300">
                <div class="w-3 h-3 rounded-full bg-error/60"></div>
                <div class="w-3 h-3 rounded-full bg-warning/60"></div>
                <div class="w-3 h-3 rounded-full bg-success/60"></div>
                <span class="ml-2 text-xs text-base-content/40 font-mono">CraftBlog.java</span>
              </div>
              <!-- Code content -->
              <div class="p-5 font-mono text-sm leading-relaxed">
                <p><span class="text-secondary">public class</span> <span class="text-primary font-semibold">CraftBlog</span> {'{'}</p>
                <p class="pl-6 mt-1"><span class="text-base-content/40">// Partager, apprendre, progresser</span></p>
                <p class="pl-6 mt-2"><span class="text-secondary">private final</span> Passion <span class="text-base-content">passion</span>;</p>
                <p class="pl-6"><span class="text-secondary">private final</span> Curiosity <span class="text-base-content">curiosity</span>;</p>
                <p class="mt-3 pl-6"><span class="text-secondary">public</span> Article <span class="text-primary">write</span>() {'{'}</p>
                <p class="pl-12"><span class="text-secondary">return</span> <span class="text-secondary">new</span> Article(</p>
                <p class="pl-16"><span class="text-primary">this</span>.passion,</p>
                <p class="pl-16"><span class="text-primary">this</span>.curiosity</p>
                <p class="pl-12">);</p>
                <p class="pl-6">{'}'}</p>
                <p>{'}'}</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Latest Articles Section -->
  <section class="container mx-auto px-6 py-16">
    <div class="flex items-center justify-between mb-10">
      <h2 class="text-3xl font-bold section-heading">Derniers Articles</h2>
      <a href="/blog" class="text-sm font-medium text-primary hover:underline hidden sm:flex items-center gap-1">
        Tous les articles
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
        </svg>
      </a>
    </div>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 stagger-children">
      {posts.map(post => (
        <div class="animate-fade-in-up">
          <ArticleCard
            title={post.data.title}
            description={post.data.description}
            image={post.data.image}
            slug={post.slug}
            author={post.data.author}
            date={post.data.date}
          />
        </div>
      ))}
    </div>

    <!-- Mobile CTA -->
    <div class="mt-10 text-center sm:hidden">
      <a href="/blog" class="btn btn-primary btn-sm">
        Voir tous les articles →
      </a>
    </div>
  </section>
</BlogLayout>
