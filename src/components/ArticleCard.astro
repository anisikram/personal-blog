---
interface Props {
  title: string;
  description: string;
  image?: string;
  slug: string;
  author: string;
  date: Date;
  variant?: 'default' | 'featured';
}

const { title, description, image, slug, author, date, variant = 'default' } = Astro.props;

const formattedDate = date.toLocaleDateString('fr-FR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<a href={`/blog/${slug}/`} class="group block h-full">
  <article class={`card bg-base-100 h-full overflow-hidden border border-base-200 shadow-sm transition-all duration-300 hover:shadow-xl hover:-translate-y-1.5 hover:border-primary/30 ${variant === 'featured' ? 'lg:card-side' : ''}`}>
    {image && (
      <figure class={`overflow-hidden ${variant === 'featured' ? 'lg:w-2/5' : 'h-52 sm:h-56'}`}>
        <img
          src={image}
          alt={title}
          class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
          loading="lazy"
        />
      </figure>
    )}
    <div class={`card-body justify-between ${variant === 'featured' ? 'lg:w-3/5' : ''}`}>
      <div>
        <h3 class="card-title text-lg font-bold leading-snug group-hover:text-primary transition-colors duration-200">
          {title}
        </h3>
        <p class="mt-2 text-sm text-base-content/70 line-clamp-2">
          {description}
        </p>
      </div>
      <div class="mt-4 flex items-center gap-3 text-xs text-base-content/50">
        <div class="flex items-center gap-1.5">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd" />
          </svg>
          <span>{author}</span>
        </div>
        <span class="text-base-content/30">•</span>
        <div class="flex items-center gap-1.5">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd" />
          </svg>
          <time datetime={date.toISOString()}>{formattedDate}</time>
        </div>
      </div>
    </div>
  </article>
</a>
